{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach React Host (After Split Task)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": true
    },
    {
      "name": "Debug React Host (WPF)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare-react-host-debug",
      "program": "${workspaceFolder}/src/Intune.Commander.DesktopReact/bin/Debug/net10.0-windows/Intune.Commander.DesktopReact.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/Intune.Commander.DesktopReact",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    }
  ]
}
