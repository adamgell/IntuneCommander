<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:aedit="https://github.com/avaloniaui/avaloniaedit"
             xmlns:controls="using:Intune.Commander.Desktop.Views.Controls"
             x:Class="Intune.Commander.Desktop.Views.Controls.PowerShellCodeBlock"
             x:DataType="controls:PowerShellCodeBlock">
    <Border Background="#1E1E1E" CornerRadius="6" ClipToBounds="True">
        <DockPanel>
            <!-- Title bar -->
            <Border DockPanel.Dock="Top" Background="#2D2D2D" Padding="10,6">
                <DockPanel>
                    <TextBlock Text="PowerShell" FontSize="11" Foreground="#858585"
                               FontFamily="Consolas,Courier New,monospace" VerticalAlignment="Center" />
                    <TextBlock Text=".ps1" FontSize="11" Foreground="#569CD6"
                               FontFamily="Consolas,Courier New,monospace"
                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                </DockPanel>
            </Border>
            <!-- Code editor (read-only with TextMate syntax highlighting) -->
            <aedit:TextEditor x:Name="Editor"
                              IsReadOnly="True"
                              ShowLineNumbers="True"
                              FontFamily="Consolas,Courier New,monospace"
                              FontSize="12"
                              Background="#1E1E1E"
                              Foreground="#D4D4D4"
                              Padding="4,4"
                              MinHeight="80"
                              MaxHeight="300"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              WordWrap="False" />
        </DockPanel>
    </Border>
</UserControl>
