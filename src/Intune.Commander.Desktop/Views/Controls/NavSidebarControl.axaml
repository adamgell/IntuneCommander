<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:icons="clr-namespace:Material.Icons;assembly=Material.Icons"
             x:Class="Intune.Commander.Desktop.Views.Controls.NavSidebarControl"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="TextBlock.PrototypeNavGroupLabel">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#7F8894" />
            <Setter Property="Margin" Value="8,6,0,3" />
        </Style>
        <Style Selector="Button.NavItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="5,6" />
            <Setter Property="Margin" Value="3,1" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#B7C0CA" />
        </Style>
        <Style Selector="Button.NavItem /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <Style Selector="Button.NavItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A3139" />
        </Style>
        <Style Selector="Button.NavItem.active">
            <Setter Property="Foreground" Value="#F3F7FB" />
        </Style>
        <Style Selector="Button.NavItem.active /template/ ContentPresenter">
            <Setter Property="Background" Value="#355C88" />
        </Style>
    </UserControl.Styles>

    <DockPanel Background="#20252B">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="0" Margin="0,6,0,10">
                <TextBlock Text="OVERVIEW" Classes="PrototypeNavGroupLabel" />

                <Button Command="{Binding SelectNavItemCommand}" CommandParameter="Overview"
                        Classes="NavItem"
                        Classes.active="{Binding IsOverviewCategory}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Border Width="15" Height="15" Background="#252B33" BorderBrush="#4F5966" BorderThickness="1">
                            <mi:MaterialIcon Kind="{x:Static icons:MaterialIconKind.ViewDashboard}"
                                             Width="10" Height="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Overview" FontSize="11" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <ItemsControl ItemsSource="{Binding NavGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NavCategoryGroup">
                            <StackPanel Margin="0,6,0,0">
                                <TextBlock Text="{Binding NameUpper}" Classes="PrototypeNavGroupLabel" />
                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:NavCategory">
                                            <Button Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).SelectNavItemCommand}"
                                                    CommandParameter="{Binding Name}"
                                                    Classes="NavItem"
                                                    Classes.active="{Binding IsSelected}">
                                                <StackPanel Orientation="Horizontal" Spacing="7">
                                                    <Border Width="15" Height="15" Background="#252B33" BorderBrush="#4F5966" BorderThickness="1">
                                                        <mi:MaterialIcon Kind="{Binding Icon}" Width="10" Height="10" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>
