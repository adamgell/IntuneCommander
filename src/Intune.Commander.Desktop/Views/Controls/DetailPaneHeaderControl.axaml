<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             x:Class="Intune.Commander.Desktop.Views.Controls.DetailPaneHeaderControl"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Button.PrototypeDetailCommand">
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#2E343C" />
            <Setter Property="BorderBrush" Value="#586270" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
    </UserControl.Styles>

    <StackPanel>
        <Border Padding="8,5"
                Background="#222830"
                BorderBrush="#434B56"
                BorderThickness="1,1,1,0">
            <DockPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="Details"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#E6EDF3" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <Border Padding="4,2" BorderBrush="#434B56" BorderThickness="1" Background="#1D2228">
                            <TextBlock Text="{Binding SelectedCategory.Name, FallbackValue='Current category'}"
                                       FontSize="11"
                                       Foreground="#B7C0CA" />
                        </Border>
                        <Border Padding="4,2"
                                BorderBrush="#434B56"
                                BorderThickness="1"
                                Background="#1D2228"
                                IsVisible="{Binding IsLoadingDetails}">
                            <TextBlock Text="Refreshing selection..."
                                       FontSize="11"
                                       Foreground="#B7C0CA" />
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
                    <Button Content="Refresh"
                            Command="{Binding RefreshSelectedItemCommand}"
                            IsEnabled="{Binding CanRefreshSelectedItem}"
                            Classes="PrototypeDetailCommand"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Refresh this item from Graph" />
                    <Button Content="JSON"
                            Command="{Binding ViewRawJsonCommand}"
                            IsEnabled="{Binding CanRefreshSelectedItem}"
                            Classes="PrototypeDetailCommand"
                            VerticalAlignment="Center"
                            ToolTip.Tip="View raw Graph JSON object" />
                    <Button Content="Copy"
                            Command="{Binding CopyDetailsToClipboardCommand}"
                            Classes="PrototypeDetailCommand"
                            VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ProgressBar IsIndeterminate="True"
                     IsVisible="{Binding IsLoadingDetails}"
                     Height="2"
                     Margin="0,0,0,2"
                     Foreground="#4B78A6"
                     Background="#151A21" />
    </StackPanel>
</UserControl>
