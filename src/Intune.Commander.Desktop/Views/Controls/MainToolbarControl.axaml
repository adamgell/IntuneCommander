<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Intune.Commander.Desktop.Views.Controls.MainToolbarControl"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Button.PrototypeToolbarButton">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#2E343C" />
            <Setter Property="BorderBrush" Value="#586270" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
        <Style Selector="DropDownButton.PrototypeToolbarButton">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#2E343C" />
            <Setter Property="BorderBrush" Value="#586270" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
        <Style Selector="Button.PrototypeToolbarPrimary">
            <Setter Property="Background" Value="#355C88" />
            <Setter Property="BorderBrush" Value="#4B78A6" />
        </Style>
        <Style Selector="ComboBox.PrototypeProfilePicker">
            <Setter Property="MinWidth" Value="200" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Background" Value="#12171D" />
            <Setter Property="BorderBrush" Value="#48515D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
        <Style Selector="TextBlock.PrototypeContextLabel">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#99A3AE" />
        </Style>
        <Style Selector="TextBlock.PrototypeContextValue">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="#E6EDF3" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Border.PrototypeContextDivider">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Background" Value="#434B56" />
        </Style>
    </UserControl.Styles>

    <StackPanel>
        <Border Background="#242A31"
                BorderBrush="#474F5A"
                BorderThickness="0,0,0,1">
            <Grid RowDefinitions="Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="8,6,8,4">
                    <DropDownButton Content="Actions"
                                    Classes="PrototypeToolbarButton">
                        <DropDownButton.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedLeft">
                                <MenuItem Header="Refresh" Command="{Binding RefreshCommand}" />
                                <MenuItem Header="Group Lookup" x:Name="GroupLookupButton" />
                                <Separator />
                                <MenuItem Header="Export Selected" Command="{Binding ExportSelectedCommand}" />
                                <MenuItem Header="Export Checked" Command="{Binding ExportCheckedCommand}" IsEnabled="{Binding HasCheckedItems}" />
                                <MenuItem Header="Export All" Command="{Binding ExportAllCommand}" />
                                <Separator />
                                <MenuItem Header="Import..." x:Name="ImportMenuItem" />
                            </MenuFlyout>
                        </DropDownButton.Flyout>
                    </DropDownButton>

                    <Button Command="{Binding DownloadAllToCacheCommand}"
                            IsVisible="{Binding !IsDownloadingAll}"
                            ToolTip.Tip="Downloads all Intune data types into the local cache"
                            Classes="PrototypeToolbarButton PrototypeToolbarPrimary">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Download" Width="13" Height="13" />
                            <TextBlock Text="Download All to Cache" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding CancelDownloadAllCommand}"
                            IsVisible="{Binding IsDownloadingAll}"
                            Classes="PrototypeToolbarButton"
                            Background="#6A3131"
                            BorderBrush="#954747">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Stop" Width="13" Height="13" />
                            <TextBlock Text="Cancel Download" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding RefreshCommand}"
                            Classes="PrototypeToolbarButton">
                        <TextBlock Text="Refresh" VerticalAlignment="Center" />
                    </Button>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#1D2228"
                        BorderBrush="#434B56"
                        BorderThickness="0,1,0,0"
                        Padding="8,4">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Profile"
                                   Classes="PrototypeContextLabel"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />

                        <ComboBox ItemsSource="{Binding SwitcherProfiles}"
                                  SelectedItem="{Binding SelectedSwitchProfile}"
                                  IsEnabled="{Binding !IsBusy}"
                                  Classes="PrototypeProfilePicker">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <Border Classes="PrototypeContextDivider" />

                        <TextBlock Text="Detail pane"
                                   Classes="PrototypeContextLabel"
                                   Margin="0,0,6,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="On"
                                   Classes="PrototypeContextValue"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding IsDetailPaneVisible}" />
                        <TextBlock Text="Off"
                                   Classes="PrototypeContextValue"
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding !IsDetailPaneVisible}" />
                    </WrapPanel>
                </Border>
            </Grid>
        </Border>

        <Border Margin="8,3,8,0"
                Background="#1D2228"
                BorderBrush="#434B56"
                BorderThickness="1"
                Padding="6,4"
                IsVisible="{Binding IsDownloadingAll}">
            <StackPanel Spacing="3">
                <ProgressBar IsIndeterminate="False"
                             Maximum="100"
                             Value="{Binding DownloadProgressPercent}"
                             Height="4"
                             Foreground="#4B78A6"
                             Background="#151A21"
                             CornerRadius="0" />
                <TextBlock Text="{Binding DownloadProgress}"
                           FontSize="11"
                           HorizontalAlignment="Left"
                           Foreground="#99A3AE" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
