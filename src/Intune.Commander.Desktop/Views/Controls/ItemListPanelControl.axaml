<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Intune.Commander.Desktop.ViewModels"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="Intune.Commander.Desktop.Views.Controls.ItemListPanelControl"
             x:DataType="vm:MainWindowViewModel">
    <UserControl.Styles>
        <Style Selector="Button.PrototypeListCommand">
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#2E343C" />
            <Setter Property="BorderBrush" Value="#586270" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
        <Style Selector="ToggleButton.PrototypeListCommand">
            <Setter Property="Padding" Value="7,3" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="#2E343C" />
            <Setter Property="BorderBrush" Value="#586270" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
        <Style Selector="TextBox.PrototypeSearchBox">
            <Setter Property="Background" Value="#12171D" />
            <Setter Property="BorderBrush" Value="#48515D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Foreground" Value="#E6EDF3" />
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="8,8,10,6">
        <Border DockPanel.Dock="Top"
                Margin="0,0,0,6"
                Padding="8,6,8,5"
                Background="#222830"
                BorderBrush="#434B56"
                BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                <TextBlock Text="{Binding SelectedCategory.Name, FallbackValue='Items'}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#E6EDF3"
                           VerticalAlignment="Center" />

                <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemHeight="22">
                    <Button Content="Export CSV"
                            Command="{Binding ExportAppAssignmentsCsvCommand}"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsAppAssignmentsCategory}" />
                    <Button Content="Export CSV"
                            Command="{Binding ExportGroupsCsvCommand}"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center">
                        <Button.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.Or}">
                                <Binding Path="IsDynamicGroupsCategory" />
                                <Binding Path="IsAssignedGroupsCategory" />
                            </MultiBinding>
                        </Button.IsVisible>
                    </Button>
                    <Button Content="Export CSV"
                            Command="{Binding ExportSettingsCatalogCsvCommand}"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsSettingsCatalogCategory}"
                            ToolTip.Tip="Export Settings Catalog policies list to CSV" />
                    <Button Content="Export CSV"
                            Command="{Binding ExportCompliancePoliciesCsvCommand}"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsCompliancePolicyCategory}"
                            ToolTip.Tip="Export Compliance Policies list to CSV" />
                    <Button Content="Export CSV"
                            Command="{Binding ExportAdminTemplatesCsvCommand}"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsAdministrativeTemplatesCategory}"
                            ToolTip.Tip="Export Administrative Templates list to CSV" />
                    <Button Command="{Binding ExportConditionalAccessPowerPointCommand}"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsConditionalAccessCategory}"
                            ToolTip.Tip="Export Conditional Access policies to PowerPoint presentation">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <mi:MaterialIcon Kind="Presentation" Width="13" Height="13" />
                            <TextBlock Text="Export PowerPoint" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <ToggleButton IsChecked="{Binding IsDetailPaneVisible}"
                                  Classes="PrototypeListCommand"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Toggle detail panel visibility">
                        <TextBlock Text="Details" VerticalAlignment="Center" />
                    </ToggleButton>
                    <Button Content="Columns"
                            x:Name="ColumnChooserButton"
                            Classes="PrototypeListCommand"
                            VerticalAlignment="Center" />
                </WrapPanel>

                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="6">
                    <Border Padding="4,2" BorderBrush="#434B56" BorderThickness="1" Background="#1D2228" MinWidth="170">
                        <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#B7C0CA" TextTrimming="CharacterEllipsis" />
                    </Border>
                    <Border Padding="4,2" BorderBrush="#434B56" BorderThickness="1" Background="#1D2228" MinWidth="170">
                        <TextBlock Text="{Binding CacheStatusText}" FontSize="11" Foreground="#99A3AE" TextTrimming="CharacterEllipsis" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" ColumnSpacing="6" Margin="0,0,0,6">
            <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                     Watermark="Search current category"
                     Classes="PrototypeSearchBox"
                     FontSize="12" />
            <Border Grid.Column="1"
                    Padding="7,0"
                    MinHeight="28"
                    Background="#222830"
                    BorderBrush="#434B56"
                    BorderThickness="1">
                <TextBlock Text="Live filter"
                           Foreground="#99A3AE"
                           VerticalAlignment="Center"
                           FontSize="11" />
            </Border>
        </Grid>

        <Panel>
            <Border Background="#161B22" BorderBrush="#434B56" BorderThickness="1">
                <DataGrid x:Name="MainDataGrid"
                          ItemsSource="{Binding ActiveItemsSource}"
                          SelectedItem="{Binding ActiveSelectedItem, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          FrozenColumnCount="2"
                          GridLinesVisibility="Horizontal"
                          FontSize="11"
                          RowHeight="24"
                          ColumnHeaderHeight="24"
                          Background="#161B22"
                          BorderThickness="0"
                          BorderBrush="#434B56">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Refresh Item from Graph"
                                      Command="{Binding RefreshSelectedItemCommand}"
                                      IsEnabled="{Binding CanRefreshSelectedItem}" />
                            <Separator />
                            <MenuItem Header="Export Selected"
                                      Command="{Binding ExportSelectedCommand}" />
                            <MenuItem Header="Export Checked"
                                      Command="{Binding ExportCheckedCommand}"
                                      IsEnabled="{Binding HasCheckedItems}" />
                            <MenuItem Header="Copy Details to Clipboard"
                                      Command="{Binding CopyDetailsToClipboardCommand}" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>

            <Border IsVisible="{Binding IsCurrentCategoryEmpty}"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="24,16"
                    Background="#20262D"
                    BorderBrush="#434B56"
                    BorderThickness="1">
                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <mi:MaterialIcon Kind="InboxOutline"
                                     Width="36"
                                     Height="36"
                                     Foreground="#99A3AE"
                                     HorizontalAlignment="Center"
                                     AutomationProperties.Name="Empty inbox icon"
                                     ToolTip.Tip="Empty inbox" />
                    <TextBlock Text="No items found"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#E6EDF3"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="This category is empty or no items match your search."
                               FontSize="12"
                               Foreground="#99A3AE"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="320" />
                </StackPanel>
            </Border>
        </Panel>
    </DockPanel>
</UserControl>
